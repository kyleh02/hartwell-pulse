# =============================================================================
# Hartwell Pulse — environment variables
# Copy this file to ".env.local" and fill in real values. Never commit .env.local.
# Placeholders below are intentionally not real-key-shaped so secret scanners
# don't flag them.
# =============================================================================

# -----------------------------------------------------------------------------
# Clerk (authentication) — https://dashboard.clerk.com -> API keys
# Sign-up is disabled (Kyle provisions clients). Add a session-token claim
# { "role": "authenticated" } so Supabase RLS recognises the user.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=__your_clerk_publishable_key__
CLERK_SECRET_KEY=__your_clerk_secret_key__
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in
CLERK_WEBHOOK_SIGNING_SECRET=__your_clerk_webhook_signing_secret__

# -----------------------------------------------------------------------------
# Supabase (database + storage) — Project Settings -> API
# The service role key bypasses RLS — server only, never expose it.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=__your_supabase_anon_key__
SUPABASE_SERVICE_ROLE_KEY=__your_supabase_service_role_key__

# -----------------------------------------------------------------------------
# Resend (transactional + digest email) — https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=__your_resend_api_key__
EMAIL_FROM="Kyle at Hartwell Digital <admin@hartwelldigital.com>"

# Protects the cron endpoints (/api/cron/*). Any long random string; Vercel Cron
# sends it as a Bearer token in production.
CRON_SECRET=__a_long_random_string__

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
